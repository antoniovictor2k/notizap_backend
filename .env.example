# ─── SERVER ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── FIREBASE ──────────────────────────────────────────────
# Cole o conteúdo JSON da sua service account do Firebase
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── MERCADO PAGO (preparado, não ativado) ─────────────────
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=sua_chave_secreta

# ─── RATE LIMIT ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
MSG_PER_MINUTE_LIMIT=20
